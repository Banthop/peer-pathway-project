{
  "redirects": [
    { "source": "/", "destination": "/webinar", "permanent": false }
  ],
  "rewrites": [
    { "source": "/webinar", "destination": "/index.html" },
    { "source": "/da-webinar", "destination": "/index.html" },
    { "source": "/portal/:path*", "destination": "/index.html" },
    { "source": "/general-portal/:path*", "destination": "/index.html" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/email-proof.png", "destination": "/email-proof.png" },
    { "source": "/spring-week-checklist", "destination": "/spring-week-checklist.html" },
    { "source": "/spring-week-conversion-checklist.pdf", "destination": "/spring-week-conversion-checklist.pdf" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
